# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase service role key — SERVER ONLY, never expose to client
# Found in: Supabase dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App URL — set to your Vercel deployment URL in production (e.g. https://fleet-manager.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Cloud import integrations
NEXT_PUBLIC_ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: health checks and alerting
# If set, callers must send Authorization: Bearer <token> to /api/health
HEALTHCHECK_TOKEN=
# Incoming webhook URL for degraded health alerts (Slack/Teams/PagerDuty, etc.)
ALERT_WEBHOOK_URL=

# Resend (used by Supabase Auth for signup/password reset emails when configured)
RESEND_API_KEY=
